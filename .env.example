# Database
DATABASE_URL=postgresql://user:password@localhost:5432/store_locator

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_HOUR=100
RATE_LIMIT_PER_MINUTE=10

# Geocoding cache TTL (in days)
GEOCODING_CACHE_TTL_DAYS=30

# Search result cache TTL (in seconds)
SEARCH_CACHE_TTL_SECONDS=300

# Redis (optional - leave blank to use in-memory cache)
REDIS_URL=

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
